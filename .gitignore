# 依赖
node_modules/

# 构建产物
dist/
dist-ssr/
dist-web/
*.local

# Tauri 构建产物
src-tauri/target/

# Tauri 自动生成的 Schema（构建时生成，无需版本控制）
src-tauri/gen/schemas/

# 编辑器
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.user
*.sln.docstates

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 报名辅助文件 (仅本地使用, 不入库)
# 远程仓库仅保留前端网页 docs/index.html + docs/images/
docs/MiaoChuangShuo-TRAE-Registration.html
docs/inline_images.py
docs/报名文案.md

# 日志
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 环境变量
.env
.env.local
.env.*.local

# Git 提交消息临时文件
_commitmsg.tmp
_releasenotes.md
_*.tmp

# Novelforge 运行时产物（.novelforge/config.json 需纳入版本控制，其余忽略）
.novelforge/index/
.novelforge/migration_state.json
.novelforge/migration_backup_*/
.novelforge/.writable_test
.novelforge/snapshots/
.novelforge/*.tmp

# 备份文件（.pmd 迁移与旧版迁移产生）
*.bak
*.txt.bak

